{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "DOM.Iterable", "ES2023", "ScriptHost"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noEmitOnError": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2023",
    "useDefineForClassFields": false,
    "paths": {
      "openclaw/plugin-sdk": ["./src/plugin-sdk/index.ts"],
      "openclaw/plugin-sdk/*": ["./src/plugin-sdk/*.ts"],
      "openclaw/plugin-sdk/account-id": ["./src/plugin-sdk/account-id.ts"]
    }
  },
  "include": ["src/**/*", "ui/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/agents/tools/canvas-tool.ts",
    "src/agents/tools/nodes-tool.ts",
    "src/agents/tools/nodes-tool.test.ts",
    "src/cli/clawbot-cli.ts",
    "src/cli/nodes-cli.coverage.test.ts",
    "src/cli/program.nodes-basic.e2e.test.ts",
    "src/cli/program.nodes-media.e2e.test.ts",
    "src/cli/qr-dashboard.integration.test.ts",
    "src/infra/update-startup.test.ts"
  ]
}
